# Video-MCP Environment Configuration Example

# Kling AI API key (from https://api.klingai.com/)
KLING_API_KEY=your_kling_api_key_here

# ElevenLabs voice generation API key (from https://elevenlabs.io/)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Hailuo / MiniMax AI API key
HAILUO_API_KEY=your_hailuo_api_key_here

# Optional: Google Veo API key
VEO_API_KEY=your_veo_api_key_here

# Workspace configuration
VIDEO_MCP_WORK_DIR=/tmp/video-mcp
VIDEO_MCP_DEFAULT_PROVIDER=kling
VIDEO_MCP_LOG_LEVEL=INFO
VIDEO_MCP_MAX_FILE_SIZE_MB=500
