# Required — get free keys:
# Kling: https://klingai.com → Dashboard → API
KLING_API_KEY=

# ElevenLabs: https://elevenlabs.io → Profile → API Keys (10k chars/month free)
ELEVENLABS_API_KEY=

# Optional
HAILUO_API_KEY=
VEO_API_KEY=

# Workspace
VIDEO_MCP_WORK_DIR=/tmp/video-mcp
VIDEO_MCP_DEFAULT_PROVIDER=kling
VIDEO_MCP_LOG_LEVEL=INFO
VIDEO_MCP_MAX_FILE_SIZE_MB=500
