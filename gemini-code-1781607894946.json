    {
      "parameters": {
        "jsCode": "const scenes = [];\nconst numScenes = $('Parse_Scenes').all().length;\nfor (let i = 0; i < numScenes; i++) {\n  try {\n    const videoNode = $('Upload_Video').all(0, i);\n    const audioNode = $('Upload_Audio').all(0, i);\n    const original = $('Parse_Scenes').all()[i].json;\n    scenes.push({\n      scene_number: original.scene_number || (i + 1),\n      video_url: (videoNode && videoNode[0]) ? videoNode[0].json.webContentLink : '',\n      audio_url: (audioNode && audioNode[0]) ? audioNode[0].json.webContentLink : '',\n      narration: original.narration || ''\n    });\n  } catch (e) {\n    console.log(\"Error extracting loop data\", e);\n  }\n}\nscenes.sort((a, b) => a.scene_number - b.scene_number);\nreturn [{ json: { scenes, total_scenes: scenes.length } }];"
      },
